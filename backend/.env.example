# ─────────────────────────────────────────────────────────────
#  AuraCraft Backend — Environment Variables
#  Copy this file to .env and fill in all values before running
# ─────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas ────────────────────────────────────────────
# Get this from: https://cloud.mongodb.com → Connect → Drivers
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/auracraft?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_64_characters_long_change_this
JWT_EXPIRES_IN=7d

# ── Razorpay (test mode) ─────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys (Test Mode)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Firebase Admin SDK ───────────────────────────────────────
# Download service account JSON from:
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then set each field below OR set FIREBASE_SERVICE_ACCOUNT_JSON as the entire JSON string
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# ── Frontend URL (CORS) ──────────────────────────────────────
# Development: http://localhost:5173  (Vite dev server)
# Production: https://your-app.netlify.app
FRONTEND_URL=http://localhost:5173

# ── Optional: paid SMS gateway alternative ──────────────────
# MSG91_API_KEY=your_msg91_api_key
# MSG91_SENDER_ID=ACRAFT
# TWILIO_ACCOUNT_SID=ACxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+15005550006
